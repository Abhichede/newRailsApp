<%- model_class = Partner -%>

<div class="page-header investors-page-header">
  <h3><%= 'Partners'.upcase %></h3>
  <span class="action-section">
        <%= form_tag partners_path, method: :get, id: 'partners_search_form',
                     class: 'form-inline' do %>
            <div class="input-group input-group-sm">
              <%= text_field_tag :search_partner, params[:search_partner],placeholder: 'Search',
                                 class: 'form-control', id: 'partner-search-box' %>
              <span class="input-group-btn">
                  <%= button_tag(type: :submit, class: 'btn btn-success btn-sm', id: '') do %>
                    <i class="fa fa-search"></i>
                  <% end %>
                </span>
            </div>
        <% end %>
    <%= link_to 'Add Partner',
                new_partner_path,
                :class => 'btn btn-primary btn-sm' %>
    </span>
</div>

<%= render 'common/list_sort', url: partners_path, hidden_params: { search_partner: params[:search_partner] } %>

<div class="row">
  <% @partners.each do |partner| %>
    <div class="col-md-3 col-sm-5 col-xs-11">
      <div class="panel panel-primary">
        <div class="panel-heading" style="height: 6rem;">
          <h4><strong><%= partner.name %></strong></h4>
        </div>
        <div class="panel-body text-center" style="height: 10rem;">
          <strong>Contact: </strong> <%= number_to_phone(partner.mobile, :country_code => 91) %> <br />
          <%= partner.other_desc %>
        </div>
        <div class="panel-footer text-center">
          <%= link_to 'View', partner_path(partner), class: 'btn btn-warning btn-sm' %>
        </div>
      </div>
    </div>
  <% end %>
</div>
<%= will_paginate @partners, renderer: BootstrapPagination::Rails, params: { sort_by: @sort_by, sort_dir: @sort_dir, search_partner: params[:search_partner] } %>

